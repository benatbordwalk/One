# Stripe (Dashboard → Developers → API keys / Webhooks / Products)
STRIPE_SECRET_KEY=sk_live_or_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Postgres (e.g. Neon) — NextAuth adapter + Entitlement table
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# NextAuth — openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-project.vercel.app

# Magic link email (Resend — https://resend.com)
RESEND_API_KEY=re_...
# Verified domain or onboarding@resend.dev for tests
AUTH_EMAIL_FROM=Propeller <noreply@propellerdm.com>
